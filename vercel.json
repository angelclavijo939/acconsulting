{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "ac-consulting.cloud" }],
      "destination": "https://www.ac-consulting.cloud/$1",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/api/save_contact",
      "dest": "/api/save_contact.js"
    }
  ]
}
